# Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas Dashboard -> Connect -> Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/habit-tracker?retryWrites=true&w=majority

# JWT Secret Key - Use a strong, random string for production
JWT_SECRET=your_super_secret_jwt_key_12345

# Server Port
PORT=5000

# Environment Mode
NODE_ENV=production

# Frontend URL (for CORS) - Update with your deployed frontend URL
FRONTEND_URL=https://your-frontend-app.onrender.com