# Production Environment Variables
# This file is used when deploying to production (Render, Vercel, etc.)
# The backend URL will be automatically set by Render when using render.yaml

# Backend API URL - Update this with your deployed backend URL
REACT_APP_API_URL=https://habit-tracker-backend.onrender.com

# Optional: Enable production optimizations
GENERATE_SOURCEMAP=false
REACT_APP_ENV=production
